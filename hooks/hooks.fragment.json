    "subagentStop": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "afterFileEdit": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "stop": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "preCompact": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ]
  }
