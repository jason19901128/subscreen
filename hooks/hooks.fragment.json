{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "sessionEnd": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "beforeSubmitPrompt": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "afterAgentThought": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "preToolUse": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "postToolUse": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "afterAgentResponse": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "postToolUseFailure": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "beforeShellExecution": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "afterShellExecution": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
    ],
    "beforeMCPExecution": [
      { "command": "python3 ~/.cursor/subscreen/subscreen-update.py", "timeout": 3 }
